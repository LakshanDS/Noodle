# Noodle environment variables.
# Copy this file to `.env` and fill in your values.

# -----------------------------------------------------------------------------
# LLM provider API keys.
# At least one is required. Profiles reference providers by name; a profile
# will only work if the corresponding key is set.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Local / OpenAI-compatible endpoint (e.g. Ollama, vLLM, LM Studio).
# Only needed if a profile uses provider: ollama / openai-compatible.
# LOCAL_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# GitHub (Phase 1: a classic Personal Access Token is the simplest path).
# Token needs repo scope (or fine-grained: contents:write, pull-requests:write,
# issues:write) on each repo Noodle touches.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# GitHub App (Phase 2 — webhook/server mode). Leave unset for Phase 1.
# Required for `noodle serve`. The App mints short-lived per-installation tokens
# so you don't need a long-lived PAT. Permissions: contents:write,
# pull-requests:write, issues:write. Subscribe to events: issues, issue_comment.
# -----------------------------------------------------------------------------
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=        # PEM, multiline. Tip: store via a file path below.
# GITHUB_PRIVATE_KEY_FILE=
# GITHUB_WEBHOOK_SECRET=     # required for webhook signature verification
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Noodle runtime
# -----------------------------------------------------------------------------
# Path to the config file. Defaults to ./noodle.config.yaml
NOODLE_CONFIG=./noodle.config.yaml
# Logging level: trace|debug|info|warn|error
LOG_LEVEL=info

# Noodle's own GitHub login (e.g. your bot user). Used by `noodle serve` to
# scope the `assigned` webhook trigger so Noodle only runs when an issue is
# assigned to it — not when a human assigns an issue to a teammate.
# - App mode: REQUIRED to enable the assignment trigger (otherwise ignored).
# - PAT mode: optional; if unset, Noodle resolves it once from /user.
# NOODLE_LOGIN=noodle-bot
