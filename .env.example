# Noodle environment variables.
# Copy this file to `.env` and fill in your values.
#
# Optional: override the agent's display name (issue labels, comments, etc.).
# Prefer setting `agent_name` in noodle.config.yaml instead — config wins.
# NOODLE_AGENT_NAME=Noodle

# -----------------------------------------------------------------------------
# LLM provider API keys.
# At least one is required. Profiles reference providers by name; a profile
# will only work if the corresponding key is set.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Local / OpenAI-compatible endpoint (e.g. Ollama, vLLM, LM Studio).
# Only needed if a profile uses provider: ollama / openai-compatible.
# LOCAL_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# GitHub App (recommended for webhook/server mode).
# Create at: https://github.com/settings/apps/new
# Permissions needed: Issues (R/W), Pull requests (R/W), Contents (R/W)
# Subscribe to events: Issues, Issue comment
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=        # PEM, multiline. Tip: store via a file path below.
# GITHUB_PRIVATE_KEY_FILE=
GITHUB_WEBHOOK_SECRET=     # required for webhook signature verification
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Agent's own GitHub login (the app's bot username).
# Used to scope `assigned` webhook events so the agent only runs when assigned to it.
# Defaults to "<agent_name>-agent" (e.g. "noodle-agent") when unset.
NOODLE_LOGIN=noodle-agent

# -----------------------------------------------------------------------------
# GitHub PAT (simpler alternative for testing / single-user).
# Token needs repo scope (or fine-grained: contents:write, pull-requests:write,
# issues:write) on each repo Noodle touches.
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Noodle runtime
# -----------------------------------------------------------------------------
# Path to the config file. Defaults to ./noodle.config.yaml
NOODLE_CONFIG=./noodle.config.yaml
# Logging level: trace|debug|info|warn|error
LOG_LEVEL=info

# Directory for persisted pi agent sessions (one subdir per job). These hold the
# full conversation (messages, tool calls, results) for resume/inspection, and
# survive workspace disposal. Defaults to ./sessions. In a container, point this
# at a volume so sessions survive a restart.
# NOODLE_SESSIONS_DIR=./sessions

# Web UI (optional, Phase 3). When set, the dashboard at GET / and the JSON API
# under /api/* are enabled; /api/login mints a signed cookie that gates /api/runs.
# When UNSET, the UI is disabled entirely — only /health + /webhook are served
# (fail-closed). The password is also the HMAC secret for the session cookie.
# NOTE: login is transmitted in cleartext — put an internet-exposed server behind
# TLS (Caddy/nginx/Cloudflare Tunnel). /health and /webhook are never gated.
# NOODLE_UI_PASSWORD=
