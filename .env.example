# Noodle environment variables — ALL OPTIONAL.
#
# For Docker deployments, set these in docker-compose.yml's `environment:` block.
# For non-Docker, copy this file to `.env`.
#
# Everything else (profiles, API keys, GitHub creds, UI password, triggers,
# routing, system prompt, queue, scheduler) is configured via the web UI at
# /#/setup (first run) or /#/settings (after). This file carries only the
# boot-critical settings that can't live in the DB.

# SQLite database path. Docker: /data/noodle.db (on the mounted volume).
NOODLE_DB_PATH=/data/noodle.db

# Server bind host and port.
NOODLE_HOST=0.0.0.0
NOODLE_PORT=3000

# Logging verbosity: trace|debug|info|warn|error (default: info).
# LOG_LEVEL=info

# Directory for persisted agent sessions (one subdir per job). Point at a
# volume in Docker so sessions survive restarts. Defaults to ./sessions.
# NOODLE_SESSIONS_DIR=/data/sessions

# GitHub App private key as a file path (alternative to pasting the PEM text
# into the Settings page — useful for Kubernetes/Docker secrets).
# GITHUB_PRIVATE_KEY_FILE=/run/secrets/github-private-key.pem
