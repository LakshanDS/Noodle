    "dotenv": "^16.4.5",
    "fastify": "^5.9.0",
    "octokit": "^5.0.5",
    "pino": "^9.4.0",
    "simple-git": "^3.26.0",
    "typebox": "1.1.38",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
